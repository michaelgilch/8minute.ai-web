---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../lib/podcast.js';
---

<Layout
  title="Contact"
  description="Get in touch with the 8minute.ai™ Podcast team."
>
  <div class="page-header">
    <div class="container">
      <h1>Get in touch</h1>
      <p>
        We'd love to receive feedback, questions, comments, episode requests,
        or anything else you can think of.
      </p>
      <p>
        The best way to reach us is by email. We read everything, and episode
        requests genuinely shape what we cover next.
      </p>
    </div>
  </div>

  <section class="section contact-section">
    <div class="container">
      <a class="button primary" href={`mailto:${SITE.email}`}>
        {SITE.email}
      </a>
    </div>
  </section>
</Layout>

<style>
  /* Intro copy spans the full container on this page. */
  .page-header p {
    max-width: none;
  }

  /* The email button sits directly under the header; the stacked
     section padding left a hole. */
  .contact-section {
    padding-top: 0.5rem;
  }
</style>
