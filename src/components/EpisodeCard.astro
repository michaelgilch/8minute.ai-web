---
import { withBase } from '../lib/podcast.js';

const { episode } = Astro.props;
---

<article class="episode">
  <div class="episode-left">
    <img
      class="episode-art"
      src={withBase('/images/cover-art.jpg')}
      alt=""
      width="200"
      height="200"
      loading="lazy"
    />
    {episode.audioUrl && (
      <div class="episode-player" data-duration={episode.durationSeconds}>
        <audio controls preload="none" src={episode.audioUrl}></audio>
        <div class="player-controls">
          <button class="player-play" aria-label="Play episode">
            <svg class="icon-play" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M8 5.5v13l11-6.5z" />
            </svg>
            <svg class="icon-pause" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M7 5h3.5v14H7zM13.5 5H17v14h-3.5z" />
            </svg>
          </button>
          <div class="player-time">
            <span class="time-current">0:00</span> / <span class="time-total">–:––</span>
          </div>
        </div>
        <div class="player-bar" aria-label="Seek">
          <div class="player-track">
            <div class="player-progress"></div>
          </div>
        </div>
      </div>
    )}
  </div>
  <div class="episode-main">
    <div class="episode-head">
      <div class="episode-meta">
        {episode.date}{episode.duration && ` · ${episode.duration}`}
      </div>
      <h3>{episode.title}</h3>
    </div>
    <p class="episode-excerpt">{episode.excerpt}</p>
    <div class="episode-notes" set:html={episode.notesHtml} />
  </div>
  <button class="episode-toggle" aria-expanded="false" aria-label="Toggle episode details">
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <polyline points="6 9 12 15 18 9" />
    </svg>
  </button>
</article>

<script>
  // Toggle a card open/closed on click, except on the player, links, or the
  // show notes (so text can be selected and the audio controls used freely).
  document.addEventListener('click', (event) => {
    if (!(event.target instanceof Element)) return;
    const card = event.target.closest('.episode');
    if (!card) return;
    if (event.target.closest('a, .episode-player, .episode-notes')) return;
    const open = card.classList.toggle('open');
    card.querySelector('.episode-toggle')?.setAttribute('aria-expanded', String(open));
  });

  // Only one episode playing at a time. The play event doesn't bubble, so
  // listen in the capture phase.
  document.addEventListener(
    'play',
    (event) => {
      if (!(event.target instanceof HTMLAudioElement)) return;
      document.querySelectorAll('audio').forEach((audio) => {
        if (audio !== event.target) audio.pause();
      });
    },
    true
  );

  // Custom player UI. The native <audio> element (hidden by CSS, visible via
  // the noscript fallback) does the actual streaming.
  const formatTime = (seconds) => {
    const s = Math.max(0, Math.round(seconds));
    return `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
  };

  document.querySelectorAll('.episode-player').forEach((player) => {
    const audio = player.querySelector('audio');
    const playButton = player.querySelector('.player-play');
    const currentLabel = player.querySelector('.time-current');
    const totalLabel = player.querySelector('.time-total');
    const bar = player.querySelector('.player-bar');
    const progress = player.querySelector('.player-progress');
    if (!audio || !playButton) return;

    // The feed's duration shows before any audio loads; the real metadata
    // replaces it once available.
    const duration = () =>
      Number.isFinite(audio.duration) && audio.duration > 0
        ? audio.duration
        : Number(player.dataset.duration) || 0;
    totalLabel.textContent = formatTime(duration());

    playButton.addEventListener('click', () => {
      if (audio.paused) audio.play();
      else audio.pause();
    });

    audio.addEventListener('play', () => player.classList.add('playing'));
    audio.addEventListener('pause', () => player.classList.remove('playing'));
    audio.addEventListener('loadedmetadata', () => {
      totalLabel.textContent = formatTime(duration());
    });
    audio.addEventListener('timeupdate', () => {
      currentLabel.textContent = formatTime(audio.currentTime);
      const total = duration();
      if (total) progress.style.width = `${(audio.currentTime / total) * 100}%`;
    });
    audio.addEventListener('ended', () => {
      audio.currentTime = 0;
      progress.style.width = '0%';
      currentLabel.textContent = '0:00';
    });

    bar.addEventListener('click', (event) => {
      const rect = bar.getBoundingClientRect();
      const fraction = Math.min(1, Math.max(0, (event.clientX - rect.left) / rect.width));
      const applySeek = () => {
        audio.currentTime = fraction * audio.duration;
      };
      if (audio.readyState >= 1) applySeek();
      else {
        // preload="none": metadata isn't loaded until first interaction.
        audio.addEventListener('loadedmetadata', applySeek, { once: true });
        audio.load();
      }
    });
  });
</script>
