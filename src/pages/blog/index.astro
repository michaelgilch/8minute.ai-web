---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Blog"
  description="The 8minute.ai™ blog — companion articles for the podcast, coming soon."
>
  <div class="page-header">
    <div class="container">
      <h1>Blog</h1>
      <p>
        Companion articles, show notes, and deeper dives into the topics we
        cover on the podcast. Coming soon.
      </p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="prose">
        <p>
          In the meantime, the podcast is the best place to find us. New
          episodes are about eight minutes each, so you can catch up fast.
        </p>
        <a class="button primary" href="/#listen">Listen to the podcast</a>
      </div>
    </div>
  </section>
</Layout>
