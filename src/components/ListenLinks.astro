---
import { PLATFORMS } from '../lib/podcast.js';

const icons = import.meta.glob('../icons/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
});
---

<div class="platforms">
  {PLATFORMS.map((platform) => (
    <a
      class="platform"
      href={platform.url}
      target="_blank"
      rel="noopener"
    >
      <span class="icon" set:html={icons[`../icons/${platform.icon}.svg`]} />
      <span>{platform.name}</span>
    </a>
  ))}
</div>
